# Claude Code Remote Simple - Telegram Configuration
# Copy this file to .env and fill in your values

# ===== Notification Channel =====
EMAIL_ENABLED=false
LINE_ENABLED=false
TELEGRAM_ENABLED=true

# ===== Telegram Config =====
# Get Bot Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Your personal Chat ID (get it from @userinfobot on Telegram)
TELEGRAM_CHAT_ID=your-chat-id

# Whitelist (comma-separated Chat IDs allowed to use this bot)
TELEGRAM_WHITELIST=your-chat-id

# ===== System Config =====
SESSION_MAP_PATH=/full/path/to/Claude-Code-Remote-Simple/src/data/session-map.json
INJECTION_MODE=tmux
CLAUDE_CLI_PATH=claude
LOG_LEVEL=info
PTY_OUTPUT_LOG=false

# ===== Timeout Config =====
COMMAND_TIMEOUT=10000
NOTIFICATION_TIMEOUT=3000
NOTIFICATION_DISPLAY_TIME=10000
